      "./agents"
    ],
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@a-canary/pi-choose-wisely": "*",
    "@a-canary/pi-upskill": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
